FROM python:3.11-slim

# WORKDIR /app

# Layer 1: third-party deps (stable, highly cacheable)
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Layer 2: internal deps (busts when any pinned version changes)
ARG SHIE_CONFIG_VERSION
# ARG SHIE_MODELS_VERSION
# ARG SHIE_STREAM_VERSION
# ARG SHIE_STORE_VERSION
# ARG SHIE_PRODUCERS_VERSION
# ARG SHIE_CONSUMERS_VERSION
ARG SHIE_UI_VERSION

# Fail loudly if any required version arg is missing
RUN : "${SHIE_CONFIG_VERSION:?SHIE_CONFIG_VERSION build arg is required}" \
  && : "${SHIE_UI_VERSION:?SHIE_UI_VERSION build arg is required}"

RUN --mount=type=secret,id=env \
    set -o allexport && \
    . /run/secrets/env && \
    set +o allexport && \
    pip install --no-cache-dir \
      --index-url https://pypi.org/simple \
      --extra-index-url "$DEVPI_HASEK_DEV_URL" \
      --trusted-host host.docker.internal \
      "stellar-harvest-ie-config==${SHIE_CONFIG_VERSION}" \
      "stellar-harvest-ie-ui==${SHIE_UI_VERSION}"
    # Hosted on VPS - remove '--trusted-host'

ARG UI_PORT=8000
ENV UI_PORT=${UI_PORT}

# WORKDIR /usr/local/lib/python3.11/site-packages

EXPOSE ${UI_PORT}

# Layer 3: app code / entrypoint (rarely changes)
CMD uvicorn stellar_harvest_ie_ui --host 0.0.0.0 --port $UI_PORT